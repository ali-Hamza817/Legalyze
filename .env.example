# ============================================
# LEGALYZE - ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in all required values
# DO NOT commit the actual .env file to version control

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/legalyze?retryWrites=true&w=majority

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_EXPIRE=7d

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# For production:
# NODE_ENV=production
# FRONTEND_URL=https://yourdomain.com

# ============================================
# OPENAI API - REQUIRED
# ============================================
# Get your API key from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# PINECONE VECTOR DATABASE - REQUIRED
# ============================================
# Get these from https://www.pinecone.io
PINECONE_API_KEY=pcsk_your_pinecone_api_key_here
PINECONE_INDEX_NAME=legal-documents
PINECONE_ENVIRONMENT=us-east-1

# ============================================
# AWS S3 CONFIGURATION - REQUIRED
# ============================================
# Get these from AWS IAM Console
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# ============================================
# GOOGLE OAUTH 2.0 - OPTIONAL
# ============================================
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# For production:
# CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ============================================
# EMAIL CONFIGURATION - OPTIONAL
# ============================================
# For sending notifications (Gmail example)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# ============================================
# REACT FRONTEND CONFIGURATION
# ============================================
REACT_APP_API_URL=http://localhost:5000

# For production:
# REACT_APP_API_URL=https://api.yourdomain.com
